# Copy this file to .env and fill in your configuration

# LLM model settings (OpenAI-compatible, injected by EdgeOne Makers platform)
AI_GATEWAY_API_KEY=ai-gateway-api-key
AI_GATEWAY_BASE_URL=ai-gateway-base-url

# Optional: model id (defaults to @makers/deepseek-v4-flash)
AI_GATEWAY_MODEL=ai-gateway-model-id

# Platform web_search tool authentication
WSA_API_KEY=wsa-api-key
